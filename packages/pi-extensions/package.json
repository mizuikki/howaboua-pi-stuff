{
	"name": "@howaboua/pi-extensions",
	"version": "0.0.1",
	"description": "all Howaboua Pi extensions",
	"type": "module",
	"keywords": [
		"pi-package",
		"pi",
		"howaboua"
	],
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@howaboua/pi-auto-reasoning-tool": "0.1.5",
		"@howaboua/pi-auto-trees": "0.1.3",
		"@howaboua/pi-explore-subagents": "0.1.5",
		"@howaboua/pi-markdown-workflows": "0.2.10",
		"@howaboua/pi-memories": "0.1.0",
		"@howaboua/pi-semantic-grep": "0.1.11",
		"@howaboua/pi-smart-btw": "0.1.2",
		"@howaboua/pi-subagent-review": "0.1.53",
		"@howaboua/pi-vent": "0.2.5"
	},
	"bundledDependencies": [
		"@howaboua/pi-auto-reasoning-tool",
		"@howaboua/pi-auto-trees",
		"@howaboua/pi-explore-subagents",
		"@howaboua/pi-markdown-workflows",
		"@howaboua/pi-memories",
		"@howaboua/pi-semantic-grep",
		"@howaboua/pi-smart-btw",
		"@howaboua/pi-subagent-review",
		"@howaboua/pi-vent"
	],
	"files": [
		"README.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"node_modules/@howaboua/pi-auto-reasoning-tool/src/index.ts",
			"node_modules/@howaboua/pi-auto-trees/index.ts",
			"node_modules/@howaboua/pi-explore-subagents/index.ts",
			"node_modules/@howaboua/pi-markdown-workflows/dist/index.js",
			"node_modules/@howaboua/pi-memories/src/index.ts",
			"node_modules/@howaboua/pi-semantic-grep/src/index.ts",
			"node_modules/@howaboua/pi-smart-btw/index.ts",
			"node_modules/@howaboua/pi-subagent-review/index.ts",
			"node_modules/@howaboua/pi-vent/extensions/vent.ts"
		]
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/IgorWarzocha/howaboua-pi-stuff.git",
		"directory": "packages/pi-extensions"
	},
	"homepage": "https://github.com/IgorWarzocha/howaboua-pi-stuff/tree/main/packages/pi-extensions#readme",
	"bugs": {
		"url": "https://github.com/IgorWarzocha/howaboua-pi-stuff/issues"
	},
	"scripts": {
		"prepack": "bun run ../../scripts/prepare-aggregate-package.mjs"
	}
}
