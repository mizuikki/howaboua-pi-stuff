{
	"name": "@howaboua/pi-memories",
	"version": "0.0.0",
	"type": "module",
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"scripts": {
		"check": "bun run lint && bun run typecheck",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@earendil-works/pi-coding-agent": "^0.76.0",
