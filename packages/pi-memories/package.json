		"@types/node": "^25.9.1",
		"typebox": "^1.1.38",
		"typescript": "^5.9.3"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"src",
		"README.md",
		"tsconfig.json",
		"biome.json",
		"LICENSE"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/IgorWarzocha/howaboua-pi-stuff.git",
		"directory": "packages/pi-memories"
